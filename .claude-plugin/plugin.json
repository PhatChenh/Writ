{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "writ",
  "version": "1.5.0",
  "description": "Hybrid RAG rule retrieval + session-aware workflow enforcement. Injects relevant coding rules via a 5-stage pipeline (BM25 + vector + graph traversal + RRF ranking) and enforces mode-based workflow gates (plan -> tests -> implementation).",
  "author": {
    "name": "Lucio Saldivar",
    "url": "https://github.com/infinri"
  },
  "homepage": "https://github.com/infinri/Writ",
  "repository": "https://github.com/infinri/Writ",
  "license": "MIT",
  "keywords": ["claude-code", "rag", "rules", "enforcement", "neo4j", "fastapi", "hooks", "workflow"],
  "commands": "./.claude/commands",
  "hooks": "./hooks/hooks.json",
  "agents": [
    "./.claude/agents/writ-code-quality-reviewer.md",
    "./.claude/agents/writ-explorer.md",
    "./.claude/agents/writ-implementer.md",
    "./.claude/agents/writ-plan-reviewer.md",
    "./.claude/agents/writ-planner.md",
    "./.claude/agents/writ-test-writer.md",
    "./.claude/agents/worker.md"
  ]
}
