#!/usr/bin/env bash
# Writ CLI shim: forward all args to `.venv/bin/python -m writ.cli`.
#
# Why: `python3 -m writ.cli` works only when invoked under the writ skill's
# .venv (where the writ package is installed). Outside that venv the system
# python errors with ModuleNotFoundError. This shim resolves the venv-python
# from the skill directory regardless of caller cwd, fixing the PSR-008
# Finding 3 footgun.
#
# Usage (from any cwd, once on PATH or via symlink):
#   writ analyze-friction --skill-usage --since 60
#   writ analyze-friction --playbook-compliance --since 30
#   ...etc
#
# Install (optional): symlink into your PATH:
#   ln -s "$(realpath bin/writ)" ~/.local/bin/writ
#
# Idempotent: this shim has no side effects; it only execs the venv python.

set -euo pipefail

# Resolve the skill directory from this script's own location, following
# any symlink the user might have created in PATH.
SCRIPT_PATH="$(readlink -f "$0")"
SKILL_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

# Resolve the venv python. The writ package is installed into a bootstrap venv
# whose location depends on the install: the plugin data dir
# ($CLAUDE_PLUGIN_DATA/.venv), the cache venv (~/.cache/writ/.venv), or a
# dev-checkout skill-dir venv ($SKILL_DIR/.venv). Probe all three so the shim
# works on a cache-venv-only install and survives a Writ folder move/rename.
# (Mirrors the resolution order in bin/lib/common.sh _writ_resolve_python; this
# shim stays standalone — no common.sh — so the probe is inlined.)
VENV_PY=""
for _cand in \
    "${CLAUDE_PLUGIN_DATA:+${CLAUDE_PLUGIN_DATA}/.venv/bin/python3}" \
    "$HOME/.cache/writ/.venv/bin/python3" \
    "$SKILL_DIR/.venv/bin/python3"; do
    [ -n "$_cand" ] && [ -x "$_cand" ] && { VENV_PY="$_cand"; break; }
done

if [ -z "$VENV_PY" ]; then
    echo "writ: no bootstrap venv python found" >&2
    echo "writ: probed \$CLAUDE_PLUGIN_DATA/.venv, ~/.cache/writ/.venv, $SKILL_DIR/.venv" >&2
    echo "writ: run scripts/bootstrap.sh (or scripts/bootstrap-plugin.sh) first" >&2
    exit 1
fi

exec "$VENV_PY" -m writ.cli "$@"
